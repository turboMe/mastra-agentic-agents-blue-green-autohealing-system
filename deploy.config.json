{
  "slots": {
    "A": {
      "label": "live",
      "dir": "/projekty/mastra-agentic-environment/agentic-agents",
      "port": 4111,
      "pidFile": "/projekty/mastra-agentic-environment/.deploy/slot-a.pid"
    },
    "B": {
      "label": "staging",
      "dir": "/projekty/mastra-agentic-environment/agentic-agents-staging",
      "port": 4222,
      "pidFile": "/projekty/mastra-agentic-environment/.deploy/slot-b.pid"
    }
  },
  "healthCheck": {
    "endpoint": "/health",
    "customEndpoint": "/deploy/health",
    "timeoutMs": 60000,
    "intervalMs": 3000,
    "requiredSuccesses": 1
  },
  "watchdog": {
    "enabled": true,
    "durationMinutes": 10,
    "checkIntervalSeconds": 30,
    "maxErrorsBeforeRollback": 3,
    "mongoErrorCollection": "error_logs",
    "pidFile": "/projekty/mastra-agentic-environment/.deploy/watchdog.pid",
    "alertWebhook": "https://began-democrats-fewer-anybody.trycloudflare.com/webhook/telegram-reply"
  },
  "rollback": {
    "autoRevert": true,
    "keepLogs": true,
    "logDir": "/projekty/mastra-agentic-environment/.deploy/logs",
    "backupDir": "/projekty/mastra-agentic-environment/.deploy/rollback"
  },
  "externalProjects": {
    "baseDir": "/projekty/agent-projects"
  }
}
