  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "predev": "mongosh --quiet --eval 'db.adminCommand(\"ping\")' 2>/dev/null || docker compose -f ../docker-compose.yml up -d mongo --wait",
    "dev": "mastra dev",
    "build": "mastra build",
    "prestart": "mongosh --quiet --eval 'db.adminCommand(\"ping\")' 2>/dev/null || docker compose -f ../docker-compose.yml up -d mongo --wait",
    "start": "mastra start",
    "mongo:up": "docker compose -f ../docker-compose.yml up -d mongo --wait",
    "mongo:down": "docker compose -f ../docker-compose.yml down",
    "mongo:logs": "docker compose -f ../docker-compose.yml logs -f mongo",
    "init-db": "npx tsx src/mastra/scripts/init-db.ts",
    "cron": "npx tsx src/mastra/scripts/cron-runner.ts"
  },
