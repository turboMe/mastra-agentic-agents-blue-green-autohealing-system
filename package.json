{
  "name": "agentic-agents",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "predev": "bash scripts/n8n-tunnel-up.sh",
    "dev": "bash scripts/with-node.sh mastra dev",
    "build": "bash scripts/with-node.sh mastra build",
    "prestart": "bash scripts/n8n-tunnel-up.sh",
    "start": "bash scripts/with-node.sh mastra start",
    "node:check": "bash scripts/with-node.sh",
    "mongo:up": "docker compose -f ../docker-compose.yml up -d mongo --wait",
    "mongo:down": "docker compose -f ../docker-compose.yml down mongo",
    "mongo:logs": "docker compose -f ../docker-compose.yml logs -f mongo",
    "n8n:up": "docker compose -f ../docker-compose.yml up -d n8n cloudflared",
    "n8n:down": "docker compose -f ../docker-compose.yml down n8n cloudflared",
    "n8n:logs": "docker compose -f ../docker-compose.yml logs -f n8n",
    "tunnel:up": "bash scripts/n8n-tunnel-up.sh",
    "tunnel:logs": "docker compose -f ../docker-compose.yml logs -f cloudflared",
    "tunnel:url": "docker logs af-cloudflared-n8n 2>&1 | grep -oE 'https://[-a-zA-Z0-9.]+\\.trycloudflare\\.com' | tail -n 1",
    "init-db": "bash scripts/with-node.sh npx tsx src/mastra/scripts/init-db.ts",
    "rebuild:embeddings": "bash scripts/with-node.sh npx tsx src/mastra/scripts/rebuild-embeddings.ts",
    "backfill:system-knowledge-embeddings": "bash scripts/with-node.sh npx tsx src/mastra/scripts/backfill-system-knowledge-embeddings.ts",
    "cron": "bash scripts/with-node.sh npx tsx src/mastra/scripts/cron-runner.ts",
    "check:n8n-runtime": "bash scripts/with-node.sh npx tsx src/mastra/scripts/check-n8n-runtime.ts",
    "check:automation-patterns": "bash scripts/with-node.sh npx tsx src/mastra/scripts/check-automation-patterns.ts",
    "check:automation-golden-path": "bash scripts/with-node.sh npx tsx src/mastra/scripts/check-automation-golden-path.ts",
    "check:automation-autonomy": "bash scripts/with-node.sh npx tsx src/mastra/scripts/check-automation-autonomy.ts",
    "check:automation": "npm run check:n8n-runtime && npm run check:automation-patterns && npm run check:automation-golden-path",
    "audit:n8n-managed-workflows": "bash scripts/with-node.sh npx tsx src/mastra/scripts/audit-n8n-managed-workflows.ts",
    "e2e:webhook": "bash scripts/with-node.sh npx tsx src/mastra/scripts/e2e-webhook-validate.ts",
    "audit:harness": "bash scripts/with-node.sh npx tsx src/mastra/scripts/audit-coding-generate.ts",
    "replay:harness": "bash scripts/with-node.sh npx tsx src/mastra/scripts/replay-harness-run.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@mastra/core": "^1.31.0",
    "@mastra/duckdb": "^1.2.0",
    "@mastra/editor": "^0.7.23",
    "@mastra/evals": "^1.2.2",
    "@mastra/libsql": "^1.9.1",
    "@mastra/loggers": "^1.1.1",
    "@mastra/mcp": "^1.6.0",
    "@mastra/memory": "^1.17.4",
    "@mastra/mongodb": "^1.7.4",
    "@mastra/observability": "^1.11.0",
    "@octokit/rest": "^22.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "graphology": "^0.26.0",
    "graphology-metrics": "^2.4.0",
    "mongodb": "^7.2.0",
    "ollama-ai-provider-v2": "^3.5.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "typescript-language-server": "^5.1.3",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "mastra": "^1.7.3",
    "typescript": "^6.0.3"
  }
}
