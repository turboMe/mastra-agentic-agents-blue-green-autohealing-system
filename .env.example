# =============================================================================
# GastroBridge – Mastra Agentic Environment
# Skopiuj ten plik do .env i uzupełnij wartości.
# =============================================================================

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Lokalna instancja: mongodb://localhost:27017/agentforge
# Atlas:             mongodb+srv://user:pass@cluster.mongodb.net/agentforge
MONGODB_URI=mongodb://localhost:27017/agentforge
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# ── Google / Gemini (LLM + Gmail + Calendar) ─────────────────────────────────
# Gemini API — https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# OAuth2 – potrzebne do Gmail i Calendar (credentials.json z Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# refresh token uzyskany po jednorazowej autoryzacji OAuth2
GOOGLE_REFRESH_TOKEN=

# ── n8n ───────────────────────────────────────────────────────────────────────
# Adres UI n8n (panel), np. http://localhost:5678
N8N_URL=http://localhost:5678
# Adres API n8n (używany przez narzędzia do REST calls)
N8N_BASE_URL=http://localhost:5678
# API Key z n8n → Settings → API Keys
N8N_API_KEY=

# ── Cloudflare Tunnel (auto-managed) ─────────────────────────────────────────
# Ponizsze 5 zmiennych nadpisuje skrypt agentic-agents/scripts/n8n-tunnel-up.sh
# (uruchamiany z `npm run dev` / `npm run start` / `npm run tunnel:up`).
# Skrypt czyta swiezy URL z kontenera af-cloudflared-n8n i restartuje n8n.
# Reczne ustawienie tych wartosci nie ma sensu — zostana nadpisane.
N8N_PUBLIC_WEBHOOK_BASE_URL=https://replace-me.trycloudflare.com
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PROXY_HOPS=0

# ── Runtime Topology ──────────────────────────────────────────────────────────
# local-host-network = n8n dziala lokalnie/host-network i widzi localhost hosta.
# docker-compose-network = n8n dziala w tej samej sieci compose i wymaga nazw serwisow.
RUNTIME_MODE=local-host-network
MASTRA_STUDIO_URL=http://localhost:4111
MASTRA_API_URL_FOR_N8N=http://localhost:4111
OLLAMA_BASE_URL_FOR_N8N=http://localhost:11434
MONGO_HOST_FOR_N8N=localhost:27017
MONGO_DB_NAME=agentforge

# ── Mastra Harness / jcode-inspired memory flags ─────────────────────────────
# Runtime switches for the additive harness rollout. Set a flag to false to
# return that layer to the previous flow while leaving other stages enabled.
FEATURE_CODING_PRECONTEXT=true
FEATURE_ASYNC_SEMANTIC_MEMORY=true
FEATURE_FILE_ACTIVITY_LEDGER=true
FEATURE_CODE_OUTLINE=true
FEATURE_BACKGROUND_TASKS=true
FEATURE_SOFT_INTERRUPTS=true
FEATURE_MASTRA_HARNESS=true
FEATURE_TOOL_ENVELOPE=true
FEATURE_OUTPUT_COMPACTION=true
FEATURE_HARNESS_POLICY=true
# log_only = warning/log-only; enforce = block actions that policy rejects.
HARNESS_POLICY_MODE=log_only
FEATURE_HARNESS_REPLAY=true

# ── Credentials Registry (IDs z n8n UI) ───────────────────────────────────────
N8N_CREDENTIAL_TELEGRAM_ID=
N8N_CREDENTIAL_TELEGRAM_NAME=Telegram Bot
N8N_CREDENTIAL_MONGO_ID=
N8N_CREDENTIAL_MONGO_NAME=MongoDB
N8N_CREDENTIAL_GMAIL_ID=
N8N_CREDENTIAL_GMAIL_NAME=Gmail OAuth2
N8N_CREDENTIAL_GMAIL_TYPE=googleGmailOAuth2Api
N8N_CREDENTIAL_HTTP_ID=
N8N_CREDENTIAL_HTTP_NAME=HTTP Header Auth

# Telegram ID (używany przez n8n nodes)
N8N_TELEGRAM_CHAT_ID=

# ── Tavily (web search) ───────────────────────────────────────────────────────
# https://app.tavily.com
TAVILY_API_KEY=

# ── Ollama (lokalny LLM, opcjonalnie) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Embedder (Pattern RAG, chef notes) ───────────────────────────────────────
# Provider i model embeddingowy ustawiaj tylko w:
# src/mastra/config/model-manifest.ts -> infrastructure.embedding.model

# ── NotebookLM CLI (opcjonalnie) ─────────────────────────────────────────────
# Ścieżka do binarki nlm, np. /usr/local/bin/nlm
NLM_BINARY_PATH=nlm

# ── GitHub Integration (Etap 9) ──────────────────────────────────────────────
# Personal Access Token z GitHub (scope: repo)
GITHUB_TOKEN=
# Owner i repo name
GITHUB_OWNER=turboMe
GITHUB_REPO=mastra-agentic-agents-blue-green-autohealing-system
# true = po approve tworzony jest PR na GitHubie, false = lokalny merge (legacy)
GITHUB_PR_MODE=false
# true = auto-merge po CI green, false = czeka na human approval na GH
GITHUB_AUTO_MERGE=false

# ── Mastra / Dashboard ───────────────────────────────────────────────────────
# Port na którym startuje mastra dev (domyślnie 4111)
PORT=4111
NODE_ENV=development
